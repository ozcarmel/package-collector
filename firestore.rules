rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function packageDoc(packageId) {
      return get(/databases/$(database)/documents/packages/$(packageId));
    }

    function pickupRunAfter(runId) {
      return getAfter(/databases/$(database)/documents/pickupRuns/$(runId));
    }

    function sensitiveGrantId(packageId) {
      return request.auth.uid + "_" + packageId;
    }

    function hasSensitiveGrant(packageId) {
      return exists(/databases/$(database)/documents/sensitiveAccessGrants/$(sensitiveGrantId(packageId)));
    }

    function approved() {
      return signedIn() && userDoc().data.verificationStatus == "approved";
    }

    function admin() {
      return approved() && userDoc().data.role in ["admin", "owner"];
    }

    function owner() {
      return approved() &&
        userDoc().data.role == "owner" &&
        userDoc().data.phone == "0584411883";
    }

    function ozOwnerRecord() {
      return resource.data.role == "owner" &&
        resource.data.phone == "0584411883";
    }

    function validNewSelfUser(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.id == userId &&
        request.resource.data.role == "member" &&
        request.resource.data.verificationStatus in ["phone_pending", "admin_pending"];
    }

    function validNewSelfApprovedMemberSession(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.id == userId &&
        request.resource.data.role == "member" &&
        request.resource.data.verificationStatus == "approved" &&
        request.resource.data.keys()
          .hasOnly([
            "id",
            "fullName",
            "phone",
            "role",
            "verificationStatus",
            "createdAt",
            "approvedAt"
          ]);
    }

    function validSelfApprovedMemberSessionUpdate(userId) {
      return validNewSelfApprovedMemberSession(userId) &&
        resource.data.verificationStatus in ["phone_pending", "admin_pending"];
    }

    function validSelfUserUpdate(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["fullName", "phone", "homeLocation"]);
    }

    function validAdminApproveUser() {
      return admin() &&
        resource.data.verificationStatus in ["phone_pending", "admin_pending"] &&
        request.resource.data.role == "member" &&
        request.resource.data.verificationStatus == "approved" &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "fullName",
            "phone",
            "role",
            "verificationStatus",
            "createdAt",
            "approvedAt",
            "approvedByUserId"
          ]);
    }

    function validAdminCreateApprovedMember(userId) {
      return admin() &&
        request.auth.uid != userId &&
        request.resource.data.id == userId &&
        request.resource.data.role == "member" &&
        request.resource.data.verificationStatus == "approved" &&
        request.resource.data.keys()
          .hasOnly([
            "id",
            "fullName",
            "phone",
            "role",
            "verificationStatus",
            "createdAt",
            "approvedAt",
            "approvedByUserId"
          ]);
    }

    function validPromoteApprovedMember(userId) {
      return owner() &&
        request.auth.uid != userId &&
        resource.data.role == "member" &&
        resource.data.verificationStatus == "approved" &&
        request.resource.data.role == "admin" &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(["role"]);
    }

    function validBlockApprovedRegularUser(userId) {
      return admin() &&
        request.auth.uid != userId &&
        resource.data.role == "member" &&
        resource.data.phone != "0584411883" &&
        resource.data.verificationStatus == "approved" &&
        request.resource.data.verificationStatus == "blocked" &&
        request.resource.data.blockedByUserId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["verificationStatus", "blockedAt", "blockedByUserId"]);
    }

    function validOwnerBlockManager(userId) {
      return owner() &&
        request.auth.uid != userId &&
        resource.data.role in ["admin", "owner"] &&
        !ozOwnerRecord() &&
        resource.data.verificationStatus == "approved" &&
        request.resource.data.verificationStatus == "blocked" &&
        request.resource.data.blockedByUserId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["verificationStatus", "blockedAt", "blockedByUserId"]);
    }

    function validOzOwnerSelfWrite(userId) {
      return signedIn() &&
        request.auth.uid == userId &&
        request.resource.data.id == userId &&
        request.resource.data.fullName == "עוז כרמל" &&
        request.resource.data.phone == "0584411883" &&
        request.resource.data.role == "owner" &&
        request.resource.data.verificationStatus == "approved";
    }

    function sameApprovedPhoneAsCurrent(userId) {
      let currentUser = userDoc();
      let otherUser = get(/databases/$(database)/documents/users/$(userId));
      return signedIn() &&
        currentUser.data.verificationStatus == "approved" &&
        otherUser.data.verificationStatus == "approved" &&
        otherUser.data.phone == currentUser.data.phone &&
        otherUser.data.phone != "";
    }

    function currentUserCanActAsCollector(collectorId) {
      return collectorId == request.auth.uid || sameApprovedPhoneAsCurrent(collectorId);
    }

    function validCollectorArrivalUpdate() {
      return approved() &&
        resource.data.status == "collected" &&
        currentUserCanActAsCollector(resource.data.collectorUserId) &&
        request.resource.data.status == "arrived" &&
        request.resource.data.collectorUserId == resource.data.collectorUserId &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "currentKibbutzLocation", "currentKibbutzLocationText", "updatedAt"]);
    }

    function validOwnerPackageUpdate() {
      return approved() &&
        resource.data.ownerUserId == request.auth.uid &&
        resource.data.status == "waiting" &&
        request.resource.data.status == "waiting" &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "ownerName",
            "pickupLocationId",
            "publicSummary",
            "parsedCourierCompany",
            "parsedAddresseeName",
            "parsedTrackingNumber",
            "parsedPickupDeadline",
            "updatedAt"
          ]);
    }

    function validOwnerPackageReceivedUpdate() {
      return approved() &&
        resource.data.ownerUserId == request.auth.uid &&
        resource.data.status in ["arrived", "ready_for_handoff"] &&
        request.resource.data.status == "delivered" &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "deliveredAt", "updatedAt"]);
    }

    function validOwnerPackageDelete() {
      return approved() &&
        resource.data.status == "waiting" &&
        (
          resource.data.ownerUserId == request.auth.uid ||
          sameApprovedPhoneAsCurrent(resource.data.ownerUserId)
        );
    }

    function validOwnerPackageCancel() {
      return approved() &&
        resource.data.status in ["collected", "arrived", "ready_for_handoff"] &&
        request.resource.data.status == "cancelled" &&
        request.resource.data.cancelledByUserId == request.auth.uid &&
        (
          resource.data.ownerUserId == request.auth.uid ||
          sameApprovedPhoneAsCurrent(resource.data.ownerUserId)
        ) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "cancelledAt", "cancelledByUserId", "updatedAt"]);
    }

    function validPackageCreate(packageId) {
      return approved() &&
        request.resource.data.id == packageId &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.status == "waiting" &&
        request.resource.data.keys().hasOnly([
          "id",
          "ownerUserId",
          "ownerName",
          "pickupLocationId",
          "publicSummary",
          "status",
          "parsedCourierCompany",
          "parsedAddresseeName",
          "parsedTrackingNumber",
          "parsedPickupDeadline",
          "createdAt",
          "updatedAt"
        ]);
    }

    function validCollectorPackageCollectedUpdate(packageId) {
      return approved() &&
        resource.data.status == "waiting" &&
        request.resource.data.status == "collected" &&
        request.resource.data.collectorUserId == request.auth.uid &&
        hasSensitiveGrant(packageId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "collectorUserId", "updatedAt"]);
    }

    function pickupRun(runId) {
      return get(/databases/$(database)/documents/pickupRuns/$(runId));
    }

    function pickupRunCollector(runId) {
      return pickupRun(runId).data.collectorUserId == request.auth.uid;
    }

    function validPickupRunItemAccessUpdate() {
      return approved() &&
        pickupRunCollector(resource.data.pickupRunId) &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["sensitiveMessageViewedAt", "sensitivePickupLinkOpenedAt"]);
    }

    function validPickupRunCreate(runId) {
      return approved() &&
        request.resource.data.id == runId &&
        request.resource.data.collectorUserId == request.auth.uid &&
        request.resource.data.status == "active";
    }

    function validPickupRunItemCreate(itemId) {
      let run = pickupRunAfter(request.resource.data.pickupRunId);
      let pkg = packageDoc(request.resource.data.packageId);
      return approved() &&
        request.resource.data.id == itemId &&
        request.resource.data.itemStatus == "pending" &&
        run.data.collectorUserId == request.auth.uid &&
        run.data.pickupLocationId == pkg.data.pickupLocationId &&
        pkg.data.status == "waiting";
    }

    function validPickupRunItemCollectedUpdate() {
      return approved() &&
        pickupRunCollector(resource.data.pickupRunId) &&
        request.resource.data.itemStatus == "collected" &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["itemStatus", "collectedAt"]);
    }

    function validSensitiveGrantCreate(grantId) {
      let pkg = packageDoc(request.resource.data.packageId);
      let run = pickupRunAfter(request.resource.data.pickupRunId);
      return approved() &&
        request.resource.data.id == grantId &&
        grantId == sensitiveGrantId(request.resource.data.packageId) &&
        request.resource.data.viewerUserId == request.auth.uid &&
        run.data.collectorUserId == request.auth.uid &&
        run.data.pickupLocationId == pkg.data.pickupLocationId &&
        request.resource.data.pickupLocationId == pkg.data.pickupLocationId &&
        pkg.data.status == "waiting";
    }

    function validSensitiveDetailsCreate(packageId) {
      return approved() &&
        request.resource.data.packageId == packageId &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.keys().hasOnly([
          "packageId",
          "ownerUserId",
          "pickupLocationId",
          "sensitiveDeliveryMessage",
          "sensitivePickupLink",
          "sensitivePackageCode",
          "createdAt",
          "updatedAt"
        ]);
    }

    function validSensitiveDetailsOwnerUpdate(packageId) {
      let pkg = packageDoc(packageId);
      return approved() &&
        resource.data.ownerUserId == request.auth.uid &&
        resource.data.packageId == packageId &&
        pkg.data.ownerUserId == request.auth.uid &&
        pkg.data.status == "waiting" &&
        request.resource.data.packageId == packageId &&
        request.resource.data.ownerUserId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            "pickupLocationId",
            "sensitiveDeliveryMessage",
            "sensitivePickupLink",
            "sensitivePackageCode",
            "updatedAt"
          ]);
    }

    function validSensitiveDetailsOwnerDelete(packageId) {
      let pkg = packageDoc(packageId);
      return approved() &&
        resource.data.packageId == packageId &&
        pkg.data.status == "waiting" &&
        pkg.data.ownerUserId == resource.data.ownerUserId &&
        (
          resource.data.ownerUserId == request.auth.uid ||
          sameApprovedPhoneAsCurrent(resource.data.ownerUserId)
        );
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if validNewSelfUser(userId) ||
        validNewSelfApprovedMemberSession(userId) ||
        validOzOwnerSelfWrite(userId) ||
        validAdminCreateApprovedMember(userId);
      allow update: if validSelfUserUpdate(userId) ||
        validSelfApprovedMemberSessionUpdate(userId) ||
        validOzOwnerSelfWrite(userId) ||
        validAdminApproveUser() ||
        validPromoteApprovedMember(userId) ||
        validBlockApprovedRegularUser(userId) ||
        validOwnerBlockManager(userId);
      allow delete: if owner();
    }

    match /joinRequests/{requestId} {
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if admin() || (signedIn() && resource.data.userId == request.auth.uid);
      allow update: if admin() &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["status", "reviewedAt", "reviewedByUserId"]) &&
        (
          request.resource.data.status == "rejected" ||
          request.resource.data.status == "approved"
        );
      allow delete: if owner();
    }

    match /pickupLocations/{locationId} {
      allow read: if approved();
      allow write: if admin();
    }

    match /packages/{packageId} {
      allow read: if approved();
      allow create: if validPackageCreate(packageId);
      allow update: if approved() && (
        validCollectorArrivalUpdate() ||
        validCollectorPackageCollectedUpdate(packageId) ||
        validOwnerPackageReceivedUpdate() ||
        validOwnerPackageUpdate() ||
        validOwnerPackageCancel() ||
        admin()
      );
      allow delete: if admin() || validOwnerPackageDelete();
    }

    match /pickupRuns/{runId} {
      allow read: if approved() && (resource.data.collectorUserId == request.auth.uid || admin());
      allow create: if validPickupRunCreate(runId);
      allow update: if admin();
      allow delete: if admin();
    }

    match /pickupRunItems/{itemId} {
      allow read: if approved() && (pickupRunCollector(resource.data.pickupRunId) || admin());
      allow create: if validPickupRunItemCreate(itemId);
      allow update: if validPickupRunItemAccessUpdate() || validPickupRunItemCollectedUpdate() || admin();
      allow delete: if admin();
    }

    match /sensitiveAccessGrants/{grantId} {
      allow read: if approved() && (resource.data.viewerUserId == request.auth.uid || admin());
      allow create: if validSensitiveGrantCreate(grantId);
      allow update, delete: if false;
    }

    match /sensitiveAccessLogs/{logId} {
      allow create: if approved() && request.resource.data.viewerUserId == request.auth.uid;
      allow read: if admin() || resource.data.ownerUserId == request.auth.uid;
      allow update, delete: if false;
    }

    match /sensitivePackageDetails/{packageId} {
      allow read: if approved() && (
        resource.data.ownerUserId == request.auth.uid ||
        hasSensitiveGrant(packageId) ||
        admin()
      );
      allow create: if validSensitiveDetailsCreate(packageId);
      allow update: if validSensitiveDetailsOwnerUpdate(packageId);
      allow delete: if admin() || validSensitiveDetailsOwnerDelete(packageId);
    }
  }
}
